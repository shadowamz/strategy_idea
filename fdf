# SYNTHETIC DATA GENERATOR (for testing without real data)
# ═══════════════════════════════════════════════════════════════════════════════

def generate_synthetic_l2(
    n_ticks: int    = 5000,
    base_price: float = 100.0,
    tick_size: float  = 0.01,
    seed: int        = 42
) -> pd.DataFrame:
    """
    Generate realistic synthetic L2 order book data for testing.
    Simulates a simple market with mean-reverting spread and drifting price.
    """
    np.random.seed(seed)
    T = n_ticks

    # Simulate mid price as random walk
    returns = np.random.normal(0, 0.0002, T)
    mid     = base_price * np.exp(np.cumsum(returns))

    # Simulate spread (mean reverting)
    spread  = np.abs(np.random.normal(0.05, 0.01, T))
    spread  = np.clip(spread, tick_size, 0.20)

    records = []
    for t in range(T):
        m = mid[t]
        s = spread[t]
        row = {}

        # Generate 10 bid levels
        for k in range(1, LEVELS + 1):
            price = m - s / 2 - (k - 1) * tick_size * (1 + np.random.exponential(0.5))
            size  = max(1, int(np.random.exponential(500) / k))
            row[f"bid_price_{k}"] = round(price, 4)
            row[f"bid_size_{k}"]  = size

        # Generate 10 ask levels
        for k in range(1, LEVELS + 1):
            price = m + s / 2 + (k - 1) * tick_size * (1 + np.random.exponential(0.5))
            size  = max(1, int(np.random.exponential(500) / k))
            row[f"ask_price_{k}"] = round(price, 4)
            row[f"ask_size_{k}"]  = size

        records.append(row)

    df = pd.DataFrame(records)
    df.index = pd.RangeIndex(T)
    return df


