# LAYER 5 — TARGET VARIABLE ENGINEERING
# ═══════════════════════════════════════════════════════════════════════════════

def compute_targets(data: dict, horizons: list = [10, 30, 100, 500, 1000]) -> pd.DataFrame:
    """
    Build multiple prediction targets at different tick horizons.

    Targets:
        ret_N          — raw mid return over N ticks
        ret_spread_N   — mid return normalized by spread (most stationary)
        direction_N    — sign of return (classification target)
        vol_N          — realized volatility over next N ticks
    """
    mid  = data["mid"]
    sprd = data["spread"]
    T    = len(mid)
    targets = {}

    for N in horizons:
        future_mid      = np.roll(mid, -N)
        future_mid[-N:] = np.nan

        ret   = (future_mid - mid) / (mid + EPS)
        ret_s = (future_mid - mid) / (sprd + EPS)

        targets[f"ret_{N}"]          = ret
        targets[f"ret_spread_{N}"]   = ret_s
        targets[f"direction_{N}"]    = np.sign(ret)

        # Realized vol over next N ticks
        tick_ret    = np.diff(mid, prepend=mid[0]) / (mid + EPS)
        vol         = np.zeros(T)
        for t in range(T - N):
            vol[t] = tick_ret[t:t + N].std()
        vol[-N:] = np.nan
        targets[f"vol_{N}"] = vol

    return pd.DataFrame(targets)


# ═══════════════════════════════════════════════════════════════════════════════
# MASTER PIPELINE
# ═══════════════════════════════════════════════════════════════════════════════

def build_feature_matrix(
    df: pd.DataFrame,
    pca_window: int    = 200,
    n_pca_components: int = 8,
    rolling_windows: list = WINDOWS,
    target_horizons: list = [10, 30, 100, 500, 1000],
    include_rolling: bool = True,
) -> dict:
    """
    MASTER PIPELINE — transforms raw L2 snapshots into full feature matrix.

    Parameters
    ----------
    df : pd.DataFrame
        Raw L2 snapshot dataframe with columns:
        bid_price_1..10, bid_size_1..10, ask_price_1..10, ask_size_1..10

    pca_window : int
        Rolling window size for PCA latent factor computation (default 200)

    n_pca_components : int
        Number of latent book factors to extract (default 8)

    rolling_windows : list
        Tick windows for multi-scale aggregation

    target_horizons : list
        Tick horizons for target variable construction

    include_rolling : bool
        Whether to include multi-scale rolling features (large output)

    Returns
    -------
    dict with keys:
        'features'  : pd.DataFrame — full feature matrix (aligned with input)
        'targets'   : pd.DataFrame — target variables
        'data'      : dict         — normalized book arrays for inspection
        'feature_groups' : dict    — maps layer name → list of column names
    """
    print("═" * 60)
    print("  L2 ALPHA FEATURE ENGINE")
    print("═" * 60)

    print("\n[0] Ingesting & normalizing book data...")
    data = load_l2_snapshot(df)
    data = normalize_book(data)

    print("[1] Computing static book shape features...")
    static_df = compute_static_features(data)

    print("[2] Computing dynamic evolution features...")
    dynamic_df = compute_dynamic_features(data, static_df)

    print("[3] Computing hidden structure features...")
    hidden_df = compute_hidden_structure_features(
        data, static_df, pca_window=pca_window, n_components=n_pca_components
    )

    # Combine all layers
    base_features = pd.concat([static_df, dynamic_df, hidden_df], axis=1)
    base_features.index = df.index

    feature_groups = {
        "static"  : list(static_df.columns),
        "dynamic" : list(dynamic_df.columns),
        "hidden"  : list(hidden_df.columns),
    }

    if include_rolling:
        print("[4] Computing rolling multi-scale aggregations...")
        all_features = compute_rolling_features(base_features, rolling_windows)
        feature_groups["rolling"] = [
            c for c in all_features.columns if c not in base_features.columns
        ]
    else:
        all_features = base_features

    print("[5] Computing target variables...")
    targets = compute_targets(data, target_horizons)
    targets.index = df.index

    # ── Final cleanup ─────────────────────────────────────────────────────────
    all_features = all_features.replace([np.inf, -np.inf], np.nan)
    targets      = targets.replace([np.inf, -np.inf], np.nan)

    n_features = all_features.shape[1]
    n_targets  = targets.shape[1]
    print(f"\n✓ Feature matrix : {len(df)} rows × {n_features} features")
    print(f"✓ Target matrix  : {len(df)} rows × {n_targets} targets")
    print("═" * 60)

    return {
        "features"       : all_features,
        "targets"        : targets,
        "data"           : data,
        "feature_groups" : feature_groups,
    }


