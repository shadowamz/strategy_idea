# FEATURE ANALYSIS UTILITIES
# ═══════════════════════════════════════════════════════════════════════════════

def feature_correlation_report(features: pd.DataFrame, max_features: int = 50) -> pd.DataFrame:
    """
    Compute pairwise correlation matrix for top features.
    Helps identify redundant features before model training.
    """
    sample = features.dropna().iloc[:, :max_features]
    return sample.corr()


def feature_ic_report(
    features: pd.DataFrame,
    targets: pd.DataFrame,
    target_col: str = "ret_spread_100"
) -> pd.DataFrame:
    """
    Compute Information Coefficient (rank correlation) between each feature
    and the target variable. This is the standard quant way to evaluate
    predictive power without a model.
    """
    from scipy.stats import spearmanr

    target = targets[target_col].dropna()
    common_idx = features.index.intersection(target.index)
    f = features.loc[common_idx].dropna()
    t = target.loc[f.index]

    ic_data = []
    for col in f.columns:
        series = f[col]
        valid  = series.notna() & t.notna()
        if valid.sum() < 30:
            continue
        ic, pval = spearmanr(series[valid], t[valid])
        ic_data.append({
            "feature"  : col,
            "IC"       : round(ic, 4),
            "|IC|"     : round(abs(ic), 4),
            "p_value"  : round(pval, 4),
            "significant": pval < 0.05
        })

    ic_df = pd.DataFrame(ic_data).sort_values("|IC|", ascending=False)
    return ic_df


def get_clean_feature_set(
    features: pd.DataFrame,
    targets: pd.DataFrame,
    target_col: str = "ret_spread_100",
    max_correlation: float = 0.85,
    min_ic: float = 0.01
) -> pd.DataFrame:
    """
    Return a de-correlated, IC-filtered feature set ready for model training.

    Steps:
    1. Filter features with |IC| > min_ic vs target
    2. Greedily remove features with pairwise correlation > max_correlation
    3. Return clean feature matrix
    """
    # Step 1: IC filter
    ic_report = feature_ic_report(features, targets, target_col)
    good_features = ic_report[
        ic_report["significant"] & (ic_report["|IC|"] >= min_ic)
    ]["feature"].tolist()

    if not good_features:
        print("Warning: no features passed IC filter. Returning all features.")
        return features

    f = features[good_features].dropna()

    # Step 2: greedy decorrelation
    corr  = f.corr().abs()
    cols  = list(f.columns)
    keep  = []
    dropped = set()

    for col in cols:
        if col in dropped:
            continue
        keep.append(col)
        for other in cols:
            if other != col and other not in dropped:
                if corr.loc[col, other] > max_correlation:
                    dropped.add(other)

    print(f"✓ Clean feature set: {len(keep)} features "
          f"(from {len(good_features)} IC-passing, {len(cols)} total)")
    return f[keep]


