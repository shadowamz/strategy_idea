#!/usr/bin/env python3
"""
From-scratch Time-MoE (decoder-only Transformer + MoE FFN) on synthetic multivariate TS.
Generates (n, m) -> predicts (k, c) with c = m in this demo.
Saves:
  - timemoe_test_plot.png      (context + true future + predicted future for ch0)
  - timemoe_test.pth           (checkpoint)
Prints:
  - prediction shape and horizon MSE

Minimal deps: torch, matplotlib
Run: python run_timemoe_synth.py
"""
from __future__ import annotations
import math, random, os
from dataclasses import dataclass
from typing import Optional

import torch
import torch.nn as nn
import torch.nn.functional as F
import matplotlib.pyplot as plt

# --------------------------
# Model (from scratch)
# --------------------------

def causal_mask(T: int, device: torch.device) -> torch.Tensor:
    return torch.triu(torch.ones(T, T, device=device, dtype=torch.bool), diagonal=1)

class MultiheadSelfAttention(nn.Module):
    def __init__(self, d_model: int, n_heads: int, attn_dropout: float = 0.0, resid_dropout: float = 0.0):
        super().__init__()
        assert d_model % n_heads == 0
        self.d_model = d_model; self.n_heads = n_heads; self.head_dim = d_model // n_heads
        self.qkv = nn.Linear(d_model, 3 * d_model, bias=True)
        self.proj = nn.Linear(d_model, d_model, bias=True)
        self.attn_dropout = nn.Dropout(attn_dropout)
        self.resid_dropout = nn.Dropout(resid_dropout)
    def forward(self, x):
        B, T, C = x.shape
        qkv = self.qkv(x); q, k, v = qkv.chunk(3, dim=-1)
        def split(t): return t.view(B, T, self.n_heads, self.head_dim).transpose(1, 2)
        q, k, v = split(q), split(k), split(v)
        att = (q @ k.transpose(-2, -1)) / math.sqrt(self.head_dim)
        att = att.masked_fill(causal_mask(T, x.device), float('-inf'))
        att = self.attn_dropout(torch.softmax(att, dim=-1))
        y = att @ v
        y = y.transpose(1, 2).contiguous().view(B, T, C)
        y = self.resid_dropout(self.proj(y))
        return y

class MLPExpert(nn.Module):
    def __init__(self, d_model: int, expansion: int = 4, dropout: float = 0.0):
        super().__init__()
        h = expansion * d_model
        self.fc1 = nn.Linear(d_model, h); self.fc2 = nn.Linear(h, d_model); self.drop = nn.Dropout(dropout)
    def forward(self, x):
        return self.drop(self.fc2(self.drop(torch.gelu(self.fc1(x)))))

class MoE(nn.Module):
    def __init__(self, d_model: int, n_experts: int = 2, expansion: int = 4, dropout: float = 0.0):
        super().__init__()
        self.n_experts = n_experts
        self.experts = nn.ModuleList([MLPExpert(d_model, expansion, dropout) for _ in range(n_experts)])
        self.gate = nn.Linear(d_model, n_experts)
    def forward(self, x):
        B, T, C = x.shape
        probs = torch.softmax(self.gate(x), dim=-1)           # (B,T,E)
        top1 = torch.argmax(probs, dim=-1)                    # (B,T)
        top1_prob = probs.gather(-1, top1.unsqueeze(-1)).squeeze(-1)  # (B,T)
        with torch.no_grad():
            importance = probs.sum(dim=(0,1)) / (B*T)
            load = torch.nn.functional.one_hot(top1, num_classes=self.n_experts).float().sum(dim=(0,1)) / (B*T)
        aux_loss = self.n_experts * torch.sum(importance * load)
        y = torch.zeros_like(x)
        for e, expert in enumerate(self.experts):
            mask = (top1 == e)
            if not mask.any(): continue
            x_e = x[mask]; y_e = expert(x_e) * top1_prob[mask].unsqueeze(-1); y[mask] = y_e
        return y, aux_loss

class TransformerBlock(nn.Module):
    def __init__(self, d_model, n_heads, attn_dropout=0.0, resid_dropout=0.0, n_experts=2, ffw_expansion=4, ffw_dropout=0.0, use_moe=True):
        super().__init__()
        self.ln1 = nn.LayerNorm(d_model); self.attn = MultiheadSelfAttention(d_model, n_heads, attn_dropout, resid_dropout)
        self.ln2 = nn.LayerNorm(d_model); self.use_moe = use_moe
        self.ff = MoE(d_model, n_experts, ffw_expansion, ffw_dropout) if use_moe else MLPExpert(d_model, ffw_expansion, ffw_dropout)
    def forward(self, x):
        h = x + self.attn(self.ln1(x))
        if self.use_moe:
            f, aux = self.ff(self.ln2(h)); return h + f, aux
        else:
            return h + self.ff(self.ln2(h)), torch.tensor(0.0, device=x.device, dtype=x.dtype)

@dataclass
class TimeMoEConfig:
    m_in: int; c_out: int
    d_model: int = 64; n_heads: int = 4; n_layers: int = 1; n_experts: int = 2
    ffw_expansion: int = 4; attn_dropout: float = 0.0; resid_dropout: float = 0.0; ffw_dropout: float = 0.0
    max_seq_len: int = 96; tie_feedback: bool = True

class TimeMoE(nn.Module):
    def __init__(self, cfg: TimeMoEConfig):
        super().__init__(); self.cfg = cfg
        self.input_proj = nn.Linear(cfg.m_in, cfg.d_model, bias=True)
        self.pos_emb = nn.Embedding(cfg.max_seq_len, cfg.d_model)
        self.blocks = nn.ModuleList([TransformerBlock(cfg.d_model, cfg.n_heads, cfg.attn_dropout, cfg.resid_dropout, cfg.n_experts, cfg.ffw_expansion, cfg.ffw_dropout, True) for _ in range(cfg.n_layers)])
        self.ln_out = nn.LayerNorm(cfg.d_model); self.head = nn.Linear(cfg.d_model, cfg.c_out, bias=True)
        self.feedback = nn.Identity() if (cfg.tie_feedback and cfg.c_out == cfg.m_in) else nn.Linear(cfg.c_out, cfg.m_in, bias=False)
        self.apply(self._init)
    def _init(self, m):
        if isinstance(m, (nn.Linear, nn.Embedding)):
            nn.init.trunc_normal_(m.weight, std=0.02)
            if isinstance(m, nn.Linear) and m.bias is not None: nn.init.zeros_(m.bias)
        if isinstance(m, nn.LayerNorm): nn.init.ones_(m.weight); nn.init.zeros_(m.bias)
    def forward(self, x, targets=None):
        B,T,M = x.shape
        if T > self.cfg.max_seq_len: raise ValueError(f"T={T} > max_seq_len={self.cfg.max_seq_len}")
        tok = self.input_proj(x); pos = self.pos_emb(torch.arange(T, device=x.device)); h = tok + pos.unsqueeze(0)
        aux_total = torch.zeros((), device=x.device)
        for blk in self.blocks:
            h, aux = blk(h); aux_total = aux_total + aux
        h = self.ln_out(h); pred = self.head(h); out = {"pred": pred}
        if targets is not None:
            loss = F.mse_loss(pred[:,:-1,:], targets[:,1:,:]); out["loss"]=loss; out["aux_loss"]=aux_total; out["total_loss"]=loss+0.01*aux_total
        return out
    @torch.no_grad()
    def generate(self, x_cond, k:int):
        self.eval(); tokens = x_cond.clone(); preds=[]
        for _ in range(k):
            t = tokens.shape[1]; t = min(t, self.cfg.max_seq_len); x_in = tokens[:,-t:,:]
            tok = self.input_proj(x_in); pos = self.pos_emb(torch.arange(t, device=x_in.device)); h = tok + pos.unsqueeze(0)
            for blk in self.blocks: h,_ = blk(h)
            y_next = self.head(self.ln_out(h))[:,-1,:]; preds.append(y_next.unsqueeze(1))
            tokens = torch.cat([tokens, self.feedback(y_next).unsqueeze(1)], dim=1)
        return torch.cat(preds, dim=1)

# --------------------------
# Synthetic data + quick train/test
# --------------------------

def make_synthetic_series(T, m, regimes=2, noise_std=0.05, seed=None):
    if seed is not None:
        torch.manual_seed(seed); random.seed(seed)
    x = torch.zeros(T, m)
    cuts = [T//2] if regimes > 1 else []
    segments = [0] + cuts + [T]
    As = [0.6*torch.eye(m)+0.05*torch.randn(m,m) for _ in range(regimes)]
    freqs = torch.linspace(0.02, 0.08, m); phases = 2*math.pi*torch.rand(m); amps = 0.5 + torch.rand(m)
    for t in range(1, T):
        seg_idx = 0 if t-1 < segments[1] else 1 if regimes>1 else 0
        A = As[seg_idx]
        season = (amps * torch.sin(2*math.pi*freqs*t + phases))
        nonlin = 0.05 * torch.tanh(x[t-1])
        x[t] = (x[t-1] @ A.T) + season + nonlin + noise_std * torch.randn(m)
    return x

def zscore_batch(X):
    mean = X.mean(dim=1, keepdim=True); std = X.std(dim=1, keepdim=True).clamp_min(1e-6)
    return (X - mean)/std, mean, std


def main():
    # Shapes
    m=c=4
    T_train=80
    T_test_total=88
    n_context=48
    k_horizon=24

    # Data
    N_train=64; N_test=8
    train_X = torch.cat([make_synthetic_series(T_train, m, regimes=2, seed=123+i).unsqueeze(0) for i in range(N_train)], dim=0)
    test_X  = torch.cat([make_synthetic_series(T_test_total, m, regimes=2, seed=999+i).unsqueeze(0) for i in range(N_test)], dim=0)
    train_Y = train_X.clone(); test_Y = test_X.clone()

    # Normalize per-sample per-channel
    train_Xz, train_mean, train_std = zscore_batch(train_X); train_Yz = (train_Y - train_mean)/train_std
    test_Xz,  test_mean,  test_std  = zscore_batch(test_X);  test_Yz  = (test_Y  - test_mean)/test_std

    # Model
    cfg = TimeMoEConfig(m_in=m, c_out=c, d_model=64, n_heads=4, n_layers=1, n_experts=2, max_seq_len=96, tie_feedback=True)
    model = TimeMoE(cfg)

    # Brief train (one pass)
    opt = torch.optim.AdamW(model.parameters(), lr=5e-4, weight_decay=0.01)
    model.train(); BATCH=16
    idx = torch.randperm(N_train)
    for i in range(0, N_train, BATCH):
        j = idx[i:i+BATCH]
        xb, yb = train_Xz[j], train_Yz[j]
        out = model(xb, targets=yb); loss = out["total_loss"]
        opt.zero_grad(set_to_none=True); loss.backward(); nn.utils.clip_grad_norm_(model.parameters(), 1.0); opt.step()

    # Rollout
    model.eval()
    with torch.no_grad():
        x0 = test_Xz[0:1, :n_context, :]
        y_pred_z = model.generate(x0, k=k_horizon)
    y_pred = y_pred_z * test_std[0:1, :, :][:, :1, :] + test_mean[0:1, :, :][:, :1, :]
    y_true = test_Y[0:1, n_context:n_context+k_horizon, :]

    mse = float(((y_pred - y_true)**2).mean())
    print("Prediction shape:", tuple(y_pred.shape))
    print("Overall horizon MSE (small run):", mse)

    # Plot ch0
    plt.figure(figsize=(8,4))
    context = test_X[0, :n_context, 0]
    future_true = y_true[0, :, 0]
    future_pred = y_pred[0, :, 0]
    plt.plot(range(n_context), context, label="context (ch0)")
    plt.plot(range(n_context, n_context+k_horizon), future_true, label="true future (ch0)")
    plt.plot(range(n_context, n_context+k_horizon), future_pred, label="pred future (ch0)", linestyle="--")
    plt.legend(); plt.tight_layout()
    out_plot = "timemoe_test_plot.png"; plt.savefig(out_plot, dpi=150); plt.close()

    torch.save({"cfg": cfg.__dict__, "state_dict": model.state_dict()}, "timemoe_test.pth")
    print("Saved plot to:", os.path.abspath(out_plot))
    print("Saved checkpoint to:", os.path.abspath("timemoe_test.pth"))

if __name__ == "__main__":
    main()
